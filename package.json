{
  "name": "amplify-vite-react-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm install --no-ignore-optional && npm run lint && tsc && npm run typecheck:amplify && vite build && npm run generate-seo",
    "typecheck:amplify": "tsc --noEmit -p amplify/tsconfig.json",
    "generate-seo": "npx tsx scripts/generate-seo.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "preview": "vite preview",
    "optimize-images": "node scripts/optimize-images.js",
    "seed-insights": "npx tsx scripts/seed-insights.ts",
    "seed-single-insight": "npx tsx scripts/seed-single-insight.ts",
    "update-insight": "npx tsx scripts/update-insight.ts",
    "create-insight": "npx tsx scripts/create-insight.ts",
    "create-news": "npx tsx scripts/create-news.ts",
    "upload-news-image": "npx tsx scripts/upload-news-image.ts",
    "upload-product-images": "npx tsx --env-file=.env scripts/upload-product-images.ts",
    "upload-hero-cleanroom": "npx tsx --env-file=.env scripts/upload-hero-cleanroom.ts",
    "ping-search-engines": "npx tsx scripts/ping-search-engines.ts",
    "check-llms-sync": "npx tsx scripts/check-llms-sync.ts",
    "generate-equipment-guide": "npx tsx scripts/generate-equipment-guide.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@aws-amplify/ui-react": "^6.1.5",
    "@aws-sdk/client-bedrock-runtime": "^3.1014.0",
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/client-sesv2": "^3.1046.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "@sendgrid/mail": "^8.1.0",
    "@stripe/stripe-js": "^8.6.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tinymce/tinymce-react": "^6.3.0",
    "@types/react-lazy-load-image-component": "^1.6.4",
    "aws-amplify": "^6.0.17",
    "dompurify": "^3.3.3",
    "gtag": "^1.0.1",
    "isbot": "^5.1.35",
    "prop-types": "^15.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-lazy-load-image-component": "^1.6.3",
    "react-router": "^6.30.4",
    "react-router-dom": "^6.30.4",
    "react-simple-maps": "^3.0.0",
    "recharts": "^3.8.0",
    "stripe": "^20.2.0",
    "tailwindcss": "^4.2.2",
    "tinymce": "^7.9.3",
    "tldts": "^6.1.86"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.5.0",
    "@aws-amplify/backend-cli": "^1.2.9",
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/react-simple-maps": "^3.0.6",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-react": "^4.2.1",
    "aws-cdk": "^2.124.0",
    "aws-cdk-lib": "^2.124.0",
    "constructs": "^10.3.0",
    "esbuild": "^0.20.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.0.1",
    "puppeteer": "^25.3.0",
    "sharp": "^0.35.3",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.3",
    "vitest": "^3.2.4",
    "zod": "^3.25.17"
  },
  "optionalDependencies": {
    "@parcel/watcher-linux-x64-glibc": "2.5.1",
    "@rollup/rollup-linux-x64-gnu": "4.24.0"
  },
  "overrides": {
    "@remix-run/router": "^1.23.3",
    "axios": "^1.18.1",
    "fast-xml-parser": "^5.7.0",
    "form-data": "^4.0.6",
    "js-cookie": "^3.0.8",
    "lodash": "^4.18.1"
  }
}
